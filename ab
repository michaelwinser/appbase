#!/bin/sh
# appbase - Project Command Script
#
# Usage: ./ab <command> [options]
#
# Run ./ab help for full command list.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Colors (disabled if NO_COLOR set or not a terminal)
if [ -z "$NO_COLOR" ] && [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    BLUE=''
    NC=''
fi

info() { printf "${BLUE}▶${NC} %s\n" "$1"; }
success() { printf "${GREEN}✓${NC} %s\n" "$1"; }
error() { printf "${RED}✗${NC} %s\n" "$1" >&2; exit 1; }

# ===========================================
# Commands
# ===========================================

cmd_build() {
    info "Building all packages..."
    go build ./...
    success "Build complete"
}

cmd_test() {
    target="${1:-all}"

    case "$target" in
        all)
            info "Running all tests..."
            go test -v -count=1 ./...
            sh "$SCRIPT_DIR/deploy/deploy_test.sh"
            success "All tests passed"
            ;;
        unit)
            info "Running unit tests..."
            go test -v ./db/... ./auth/... ./config/... ./server/...
            success "Unit tests passed"
            ;;
        hyrums)
            info "Running consumer contract tests..."
            go test -v ./hyrums/... 2>/dev/null || echo "No consumer tests yet"
            ;;
        example|todo)
            info "Running todo example tests..."
            go test -v ./examples/todo/...
            success "Example tests passed"
            ;;
        deploy)
            info "Running deploy script tests..."
            sh "$SCRIPT_DIR/deploy/deploy_test.sh"
            success "Deploy tests passed"
            ;;
        *)
            echo "Usage: ./ab test [all|unit|hyrums|example|deploy]"
            ;;
    esac
}

cmd_run() {
    info "Running todo example..."
    mkdir -p data
    if [ -f "$SCRIPT_DIR/.env" ]; then
        set -a
        . "$SCRIPT_DIR/.env"
        set +a
    fi
    go run ./examples/todo "$@"
}

cmd_lint() {
    info "Running lints..."
    go vet ./...
    success "Lint passed"
}

cmd_devcontainer() {
    action="${1:-build}"
    case "$action" in
        build)
            info "Building devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml build
            success "Devcontainers built"
            ;;
        up)
            info "Starting devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml up -d
            success "Devcontainers started"
            ;;
        down)
            info "Stopping devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml down
            success "Devcontainers stopped"
            ;;
        shell)
            service="${2:-workspace}"
            info "Opening shell in ${service}..."
            docker compose -f .devcontainer/docker-compose.yml exec "$service" sh
            ;;
        *)
            echo "Usage: ./ab devcontainer [build|up|down|shell]"
            ;;
    esac
}

cmd_init() {
    config="app.json"

    # Read existing values if app.json exists
    if [ -f "$config" ]; then
        . "$SCRIPT_DIR/deploy/deploy.sh"
        cur_name="$(app_name)"
        cur_project="$(app_gcp_project)"
        cur_region="$(app_region)"
        info "Updating existing $config"
    else
        cur_name=""
        cur_project=""
        cur_region="us-central1"
        info "Creating $config"
    fi

    # Prompt for each value, showing current/default
    printf "App name [${cur_name:-my-app}]: "
    read -r input_name
    name="${input_name:-${cur_name:-my-app}}"

    printf "GCP project ID [${cur_project:-}]: "
    read -r input_project
    project="${input_project:-${cur_project}}"

    printf "Region [${cur_region:-us-central1}]: "
    read -r input_region
    region="${input_region:-${cur_region:-us-central1}}"

    # Build urls array — keep existing URLs if present, otherwise default
    if [ -f "$config" ]; then
        # Preserve existing urls block from the file
        existing_urls=$(sed -n '/\"urls\"/,/\]/p' "$config")
    fi

    if [ -z "$existing_urls" ]; then
        urls_block="  \"urls\": [
    \"http://localhost:3000\"
  ]"
    else
        urls_block="$existing_urls"
    fi

    # Write app.json
    cat > "$config" <<EOF
{
  "name": "$name",
  "gcpProject": "$project",
  "region": "$region",
  $urls_block
}
EOF

    success "Wrote $config"
    cat "$config"
}

cmd_secret() {
    . "$SCRIPT_DIR/deploy/deploy.sh"
    project="$(app_name)"

    if [ -z "$1" ]; then
        echo "Usage: ./ab secret <set|get|delete|list|push> [args...]"
        echo ""
        echo "Manage secrets in the OS keychain for project: $project"
        echo ""
        echo "Commands:"
        echo "  set <name> <value>    Store a secret in the keychain"
        echo "  get <name>            Retrieve a secret"
        echo "  delete <name>         Remove a secret"
        echo "  list                  List known secrets"
        echo "  push <name1,name2>    Push secrets to GCP Secret Manager"
        exit 1
    fi

    go run "$SCRIPT_DIR/cmd/secret" "$1" "$project" ${2:+"$2"} ${3:+"$3"}
}

cmd_ci() {
    info "Running full CI pipeline..."
    cmd_lint
    cmd_build
    cmd_test all
    success "CI pipeline passed"
}

cmd_provision() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    # Read name and project from app.json; only email is required as arg
    email="${1:-}"
    billing="${2:-}"
    project="$(app_gcp_project)"
    app="$(app_name)"

    if [ -z "$email" ]; then
        cat <<USAGE
Usage: ./ab provision <support-email> [billing-account]

Full GCP provisioning: project creation, billing, APIs, Firestore, OAuth.
Reads name and gcpProject from app.json.

  Current app.json:
    name:       ${app:-<not set>}
    gcpProject: ${project:-<not set>}

Example:
  ./ab provision user@example.com
USAGE
        exit 1
    fi

    if [ -z "$project" ] || [ -z "$app" ]; then
        error "app.json must have 'name' and 'gcpProject' set before provisioning."
    fi

    provision_gcp "$project" "$app" "$email" "$billing"

    # Save GCP project ID back to app.json if it was empty
    current_gcp=$(app_gcp_project)
    if [ -z "$current_gcp" ] && [ -f app.json ]; then
        sed -i'' -e "s/\"gcpProject\": \"\"/\"gcpProject\": \"$project\"/" app.json
        info "Saved gcpProject=$project to app.json"
    fi
}

cmd_deploy() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    # Source .env for OAuth credentials if present
    if [ -f "$SCRIPT_DIR/.env" ]; then
        set -a
        . "$SCRIPT_DIR/.env"
        set +a
    fi

    # Read from app.json, allow CLI overrides
    name="${1:-$(app_name)}"
    project="${2:-$(app_gcp_project)}"
    region="${3:-$(app_region)}"

    if [ -z "$name" ] || [ -z "$project" ]; then
        echo "Usage: ./ab deploy [name] [gcp-project] [region]"
        echo ""
        echo "Reads defaults from app.json. Set gcpProject there or pass as arguments."
        exit 1
    fi

    deploy_cloudrun "$name" "$project" "$region"
}

cmd_deploy_status() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    name="${1:-$(app_name)}"
    project="${2:-$(app_gcp_project)}"
    region="${3:-$(app_region)}"

    if [ -z "$name" ] || [ -z "$project" ]; then
        echo "Usage: ./ab deploy-status [name] [gcp-project] [region]"
        echo ""
        echo "Reads defaults from app.json. Set gcpProject there or pass as arguments."
        exit 1
    fi

    deploy_cloudrun_status "$name" "$project" "$region"
}

cmd_docker() {
    . "$SCRIPT_DIR/deploy/deploy.sh"
    action="${1:-up}"
    case "$action" in
        up)    deploy_docker_up ;;
        down)  deploy_docker_down ;;
        logs)  deploy_docker_logs ;;
        *)     echo "Usage: ./ab docker [up|down|logs]" ;;
    esac
}

cmd_help() {
    cat <<'EOF'
appbase - Project Command Script

Usage: ./ab <command> [options]

Development:
  build                Build all packages
  test [target]        Run tests (all, unit, hyrums, example)
  lint                 Run go vet
  ci                   Run full CI pipeline (lint + build + test)

Example App:
  run [args]           Run the todo example (e.g., ./ab run serve)
  run serve            Start todo HTTP server
  run add "title"      Add a todo via CLI
  run list             List todos via CLI

Deployment (reads name/project from app.json):
  init                               Create or update app.json (interactive)
  provision <email>                  Full GCP setup (project, billing, APIs, OAuth)
  deploy                             Deploy to Cloud Run
  deploy-status                      Show deployment status
  docker [up|down|logs]              Run app in local Docker container
  secret <set|get|delete|list|push>  Manage secrets in OS keychain

Devcontainer:
  devcontainer build   Build development containers
  devcontainer up      Start development containers
  devcontainer down    Stop development containers
  devcontainer shell   Open shell in workspace container

Other:
  help                 Show this help message

Examples:
  ./ab test                    # Run all tests
  ./ab test unit               # Run just unit tests
  ./ab run serve               # Start the todo example server
  ./ab provision me@example.com  # Full GCP setup
  ./ab deploy my-project       # Deploy to Cloud Run
  ./ab docker up               # Run locally in Docker
  ./ab ci                      # Full CI pipeline
EOF
}

# ===========================================
# Main
# ===========================================

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
    init)           cmd_init "$@" ;;
    secret)         cmd_secret "$@" ;;
    build)          cmd_build "$@" ;;
    test)           cmd_test "$@" ;;
    run)            cmd_run "$@" ;;
    lint)           cmd_lint "$@" ;;
    ci)             cmd_ci "$@" ;;
    provision)      cmd_provision "$@" ;;
    deploy)         cmd_deploy "$@" ;;
    deploy-status)  cmd_deploy_status "$@" ;;
    docker)         cmd_docker "$@" ;;
    devcontainer)   cmd_devcontainer "$@" ;;
    help|--help|-h) cmd_help ;;
    *)              error "Unknown command: $command. Run './ab help' for usage." ;;
esac
