#!/bin/sh
# appbase - Project Command Script
#
# Usage: ./ab <command> [options]
#
# Run ./ab help for full command list.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Colors (disabled if NO_COLOR set or not a terminal)
if [ -z "$NO_COLOR" ] && [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    BLUE=''
    NC=''
fi

info() { printf "${BLUE}▶${NC} %s\n" "$1"; }
success() { printf "${GREEN}✓${NC} %s\n" "$1"; }
error() { printf "${RED}✗${NC} %s\n" "$1" >&2; exit 1; }

# ===========================================
# Helpers
# ===========================================

# _load_secrets — load secrets into env vars for the current process.
# Priority: OS keychain → .env fallback.
# The keychain is the primary store. .env is for CI or environments
# without a keychain.
_load_secrets() {
    . "$SCRIPT_DIR/deploy/deploy.sh"
    project="$(app_name)"

    # Try keychain first (outputs export statements)
    keychain_exports=$(go run "$SCRIPT_DIR/cmd/secret" env "$project" 2>/dev/null || true)
    if [ -n "$keychain_exports" ]; then
        eval "$keychain_exports"
        return
    fi

    # Fallback to .env for CI / containers
    if [ -f "$SCRIPT_DIR/.env" ]; then
        set -a
        . "$SCRIPT_DIR/.env"
        set +a
    fi
}

# ===========================================
# Commands
# ===========================================

cmd_build() {
    info "Building all packages..."
    go build ./...
    success "Build complete"
}

cmd_test() {
    target="${1:-all}"

    case "$target" in
        all)
            info "Running all tests..."
            go test -v -count=1 ./...
            sh "$SCRIPT_DIR/deploy/deploy_test.sh"
            success "All tests passed"
            ;;
        unit)
            info "Running unit tests..."
            go test -v ./db/... ./auth/... ./config/... ./server/...
            success "Unit tests passed"
            ;;
        hyrums)
            info "Running consumer contract tests..."
            go test -v ./hyrums/... 2>/dev/null || echo "No consumer tests yet"
            ;;
        example|todo)
            info "Running todo example tests..."
            go test -v ./examples/todo/...
            success "Example tests passed"
            ;;
        deploy)
            info "Running deploy script tests..."
            sh "$SCRIPT_DIR/deploy/deploy_test.sh"
            success "Deploy tests passed"
            ;;
        *)
            echo "Usage: ./ab test [all|unit|hyrums|example|deploy]"
            ;;
    esac
}

cmd_codegen() {
    spec="${1:-openapi.yaml}"
    if [ ! -f "$spec" ]; then
        echo "No $spec found. Create an OpenAPI spec first."
        exit 1
    fi

    # Ensure oapi-codegen is installed
    if ! command -v oapi-codegen >/dev/null 2>&1; then
        info "Installing oapi-codegen..."
        go install github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen@latest
    fi

    mkdir -p api

    # Generate server (chi) + types
    if [ -f oapi-codegen.yaml ]; then
        info "Generating server from $spec..."
        oapi-codegen --config oapi-codegen.yaml "$spec"
    else
        info "Generating server from $spec (default config)..."
        oapi-codegen -generate chi-server,types -package api -o api/server.gen.go "$spec"
    fi

    # Generate client
    if [ -f oapi-codegen-client.yaml ]; then
        info "Generating client from $spec..."
        oapi-codegen --config oapi-codegen-client.yaml "$spec"
    else
        info "Generating client from $spec (default config)..."
        oapi-codegen -generate client,types -package api -o api/client.gen.go "$spec"
    fi

    # Generate TypeScript types if frontend exists
    if [ -d frontend ] || [ -d src ]; then
        if command -v npx >/dev/null 2>&1; then
            info "Generating TypeScript types..."
            outdir="frontend/src/lib"
            [ -d src ] && outdir="src/lib"
            mkdir -p "$outdir"
            npx openapi-typescript "$spec" -o "$outdir/api.d.ts" 2>/dev/null || echo "  (TypeScript codegen skipped)"
        fi
    fi

    success "Codegen complete"
}

cmd_run() {
    info "Running todo example..."
    mkdir -p data
    _load_secrets
    go run ./examples/todo "$@"
}

cmd_lint() {
    info "Running lints..."
    go vet ./...
    success "Lint passed"
}

cmd_lint_api() {
    info "Checking API-first pattern..."
    errors=0

    # Check 1: openapi.yaml exists
    if [ ! -f openapi.yaml ]; then
        echo "  SKIP: No openapi.yaml found (not an API-first app)"
        return 0
    fi

    # Check 2: Generated code is up to date
    if [ -d api ]; then
        tmpdir=$(mktemp -d)
        trap "rm -rf $tmpdir" EXIT

        if command -v oapi-codegen >/dev/null 2>&1 || [ -x "$(go env GOPATH)/bin/oapi-codegen" ]; then
            export PATH="$PATH:$(go env GOPATH)/bin"

            if [ -f oapi-codegen.yaml ]; then
                oapi-codegen --config oapi-codegen.yaml openapi.yaml > "$tmpdir/server.gen.go" 2>/dev/null
                if ! diff -q api/server.gen.go "$tmpdir/server.gen.go" >/dev/null 2>&1; then
                    echo "  FAIL: api/server.gen.go is out of date. Run: ./ab codegen"
                    errors=$((errors + 1))
                else
                    echo "  OK: api/server.gen.go is up to date"
                fi
            fi

            if [ -f oapi-codegen-client.yaml ]; then
                oapi-codegen --config oapi-codegen-client.yaml openapi.yaml > "$tmpdir/client.gen.go" 2>/dev/null
                if ! diff -q api/client.gen.go "$tmpdir/client.gen.go" >/dev/null 2>&1; then
                    echo "  FAIL: api/client.gen.go is out of date. Run: ./ab codegen"
                    errors=$((errors + 1))
                else
                    echo "  OK: api/client.gen.go is up to date"
                fi
            fi
        else
            echo "  SKIP: oapi-codegen not installed (cannot verify generated code)"
        fi
    fi

    # Check 3: No hand-written /api/ route registrations
    # Look for r.Get("/api/...", r.Post("/api/...", etc. outside of generated code and test files
    handwritten=$(grep -rn '\.Get("/api/\|\.Post("/api/\|\.Put("/api/\|\.Delete("/api/\|\.Patch("/api/' \
        --include="*.go" \
        --exclude="*_test.go" \
        --exclude="*.gen.go" \
        --exclude="app.go" \
        . 2>/dev/null | grep -v "/api/auth/" || true)

    if [ -n "$handwritten" ]; then
        echo "  WARN: Hand-written /api/ routes found (should be in openapi.yaml):"
        echo "$handwritten" | while IFS= read -r line; do
            echo "    $line"
        done
        # Warning, not error — there may be legitimate exceptions
    else
        echo "  OK: No hand-written /api/ routes"
    fi

    # Check 4: Server interface implementation exists
    if [ -d api ] && ! grep -rq "ServerInterface" --include="*.go" --exclude="*.gen.go" . 2>/dev/null; then
        echo "  FAIL: No ServerInterface implementation found"
        errors=$((errors + 1))
    else
        if [ -d api ]; then
            echo "  OK: ServerInterface implementation found"
        fi
    fi

    if [ "$errors" -gt 0 ]; then
        error "API lint: $errors error(s) found"
    else
        success "API lint passed"
    fi
}

cmd_devcontainer() {
    action="${1:-build}"
    case "$action" in
        build)
            info "Building devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml build
            success "Devcontainers built"
            ;;
        up)
            info "Starting devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml up -d
            success "Devcontainers started"
            ;;
        down)
            info "Stopping devcontainers..."
            docker compose -f .devcontainer/docker-compose.yml down
            success "Devcontainers stopped"
            ;;
        shell)
            service="${2:-workspace}"
            info "Opening shell in ${service}..."
            docker compose -f .devcontainer/docker-compose.yml exec "$service" sh
            ;;
        *)
            echo "Usage: ./ab devcontainer [build|up|down|shell]"
            ;;
    esac
}

cmd_init() {
    cur_name=""
    cur_project=""
    cur_region="us-central1"
    cur_port="3000"

    # Read existing values from app.yaml or app.json
    if [ -f app.yaml ]; then
        cur_name=$(grep "^name:" app.yaml 2>/dev/null | sed 's/name:[[:space:]]*//')
        cur_project=$(grep "gcp_project:" app.yaml 2>/dev/null | head -1 | sed 's/.*gcp_project:[[:space:]]*//')
        cur_port=$(grep "^port:" app.yaml 2>/dev/null | sed 's/port:[[:space:]]*//')
        info "Updating existing app.yaml"
    elif [ -f app.json ]; then
        . "$SCRIPT_DIR/deploy/deploy.sh"
        cur_name="$(app_name)"
        cur_project="$(app_gcp_project)"
        cur_region="$(app_region)"
        info "Migrating from app.json to app.yaml"
    else
        info "Creating app.yaml"
    fi

    printf "App name [${cur_name:-my-app}]: "
    read -r input_name
    name="${input_name:-${cur_name:-my-app}}"

    printf "GCP project ID [${cur_project:-}]: "
    read -r input_project
    project="${input_project:-${cur_project}}"

    printf "Port [${cur_port:-3000}]: "
    read -r input_port
    port="${input_port:-${cur_port:-3000}}"

    printf "Region [${cur_region:-us-central1}]: "
    read -r input_region
    region="${input_region:-${cur_region:-us-central1}}"

    # Write app.yaml
    cat > app.yaml <<EOF
name: $name
port: $port

store:
  type: sqlite
  path: data/app.db

environments:
  local:
    url: http://localhost:$port

  production:
    url: https://${name}.run.app
    store:
      type: firestore
      gcp_project: $project
    auth:
      client_id: \${secret:google-client-id}
      client_secret: \${secret:google-client-secret}
EOF

    success "Wrote app.yaml"
    cat app.yaml

    # Also write app.json for backward compat with deploy scripts
    cat > app.json <<EOF
{
  "name": "$name",
  "gcpProject": "$project",
  "region": "$region",
  "urls": [
    "http://localhost:$port"
  ]
}
EOF
    echo ""
    info "Also wrote app.json (deploy script compat)"
}

cmd_secret() {
    . "$SCRIPT_DIR/deploy/deploy.sh"
    project="$(app_name)"

    if [ -z "$1" ]; then
        echo "Usage: ./ab secret <command> [args...]"
        echo ""
        echo "Manage secrets in the OS keychain for project: $project"
        echo ""
        echo "Commands:"
        echo "  set <name> <value>       Store a secret in the keychain"
        echo "  get <name>               Retrieve a secret"
        echo "  delete <name>            Remove a secret"
        echo "  list                     List known secrets"
        echo "  import <creds.json>      Import Google OAuth credentials JSON"
        echo "  push <name1,name2>       Push secrets to GCP Secret Manager"
        exit 1
    fi

    go run "$SCRIPT_DIR/cmd/secret" "$1" "$project" ${2:+"$2"} ${3:+"$3"}
}

cmd_ci() {
    info "Running full CI pipeline..."
    cmd_lint
    cmd_build
    cmd_test all
    success "CI pipeline passed"
}

cmd_provision() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    # Read name and project from app.json; only email is required as arg
    email="${1:-}"
    billing="${2:-}"
    project="$(app_gcp_project)"
    app="$(app_name)"

    if [ -z "$email" ]; then
        cat <<USAGE
Usage: ./ab provision <support-email> [billing-account]

Full GCP provisioning: project creation, billing, APIs, Firestore, OAuth.
Reads name and gcpProject from app.json.

  Current app.json:
    name:       ${app:-<not set>}
    gcpProject: ${project:-<not set>}

Example:
  ./ab provision user@example.com
USAGE
        exit 1
    fi

    if [ -z "$project" ] || [ -z "$app" ]; then
        error "app.json must have 'name' and 'gcpProject' set before provisioning."
    fi

    provision_gcp "$project" "$app" "$email" "$billing"

    # Save GCP project ID back to app.json if it was empty
    current_gcp=$(app_gcp_project)
    if [ -z "$current_gcp" ] && [ -f app.json ]; then
        sed -i'' -e "s/\"gcpProject\": \"\"/\"gcpProject\": \"$project\"/" app.json
        info "Saved gcpProject=$project to app.json"
    fi
}

cmd_deploy() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    # Load secrets from keychain (primary) or .env (fallback)
    _load_secrets

    # Read from app.json, allow CLI overrides
    name="${1:-$(app_name)}"
    project="${2:-$(app_gcp_project)}"
    region="${3:-$(app_region)}"

    if [ -z "$name" ] || [ -z "$project" ]; then
        echo "Usage: ./ab deploy [name] [gcp-project] [region]"
        echo ""
        echo "Reads defaults from app.json. Set gcpProject there or pass as arguments."
        exit 1
    fi

    deploy_cloudrun "$name" "$project" "$region"
}

cmd_deploy_status() {
    . "$SCRIPT_DIR/deploy/deploy.sh"

    name="${1:-$(app_name)}"
    project="${2:-$(app_gcp_project)}"
    region="${3:-$(app_region)}"

    if [ -z "$name" ] || [ -z "$project" ]; then
        echo "Usage: ./ab deploy-status [name] [gcp-project] [region]"
        echo ""
        echo "Reads defaults from app.json. Set gcpProject there or pass as arguments."
        exit 1
    fi

    deploy_cloudrun_status "$name" "$project" "$region"
}

cmd_docker() {
    . "$SCRIPT_DIR/deploy/deploy.sh"
    action="${1:-up}"
    case "$action" in
        up)    deploy_docker_up ;;
        down)  deploy_docker_down ;;
        logs)  deploy_docker_logs ;;
        *)     echo "Usage: ./ab docker [up|down|logs]" ;;
    esac
}

cmd_help() {
    cat <<'EOF'
appbase - Project Command Script

Usage: ./ab <command> [options]

Development:
  build                Build all packages
  test [target]        Run tests (all, unit, hyrums, example)
  lint                 Run go vet
  lint-api             Verify OpenAPI codegen is up to date, no hand-written routes
  ci                   Run full CI pipeline (lint + build + test)

Example App:
  run [args]           Run the todo example (e.g., ./ab run serve)
  run serve            Start todo HTTP server
  run add "title"      Add a todo via CLI
  run list             List todos via CLI

Deployment (reads name/project from app.json):
  init                               Create or update app.json (interactive)
  provision <email>                  Full GCP setup (project, billing, APIs, OAuth)
  deploy                             Deploy to Cloud Run
  deploy-status                      Show deployment status
  docker [up|down|logs]              Run app in local Docker container
  secret <set|get|delete|list|push>  Manage secrets in OS keychain

Devcontainer:
  devcontainer build   Build development containers
  devcontainer up      Start development containers
  devcontainer down    Stop development containers
  devcontainer shell   Open shell in workspace container

Codegen:
  codegen [spec]       Generate server + client from OpenAPI spec

Other:
  help                 Show this help message

Examples:
  ./ab test                    # Run all tests
  ./ab test unit               # Run just unit tests
  ./ab run serve               # Start the todo example server
  ./ab provision me@example.com  # Full GCP setup
  ./ab deploy my-project       # Deploy to Cloud Run
  ./ab docker up               # Run locally in Docker
  ./ab ci                      # Full CI pipeline
EOF
}

# ===========================================
# Main
# ===========================================

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
    init)           cmd_init "$@" ;;
    codegen)        cmd_codegen "$@" ;;
    secret)         cmd_secret "$@" ;;
    build)          cmd_build "$@" ;;
    test)           cmd_test "$@" ;;
    run)            cmd_run "$@" ;;
    lint)           cmd_lint "$@" ;;
    lint-api)       cmd_lint_api "$@" ;;
    ci)             cmd_ci "$@" ;;
    provision)      cmd_provision "$@" ;;
    deploy)         cmd_deploy "$@" ;;
    deploy-status)  cmd_deploy_status "$@" ;;
    docker)         cmd_docker "$@" ;;
    devcontainer)   cmd_devcontainer "$@" ;;
    help|--help|-h) cmd_help ;;
    *)              error "Unknown command: $command. Run './ab help' for usage." ;;
esac
