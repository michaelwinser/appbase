# appbase Go Workspace Container
#
# Optional — developers can use host Go instead.
# Provides: Go compiler, SQLite, oapi-codegen

FROM golang:1.24-alpine

RUN apk add --no-cache \
    git \
    gcc \
    musl-dev \
    curl \
    bash \
    sqlite

# CGO needed for SQLite
ENV CGO_ENABLED=1

# Install oapi-codegen for OpenAPI code generation
RUN go install github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen@latest

WORKDIR /workspace

CMD ["sh"]
